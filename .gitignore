*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/

# Environment and local app state
.env
.env.*
!.env.example
.claude/
.streamlit/secrets.toml
.molchat_session.pkl

# Generated runtime data and local datasets
# Ignore everything under data/ (user sessions, uploads); the example seed
# data is re-included at the bottom of this file so the app ships a demo.
data/*
GLUT-1 data/
polymer_data/
models/
*.pkl
*.joblib
*.npz
*.bin
*.faiss

# Benchmarks, handoffs, and local analysis artifacts
benchmark/
benchmark_inputs/
benchmark_outputs/
handoff/
handoff-landing/
_public_release/
images/
questions.txt

# Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local
frontend/@/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Accidental Windows reserved-name files
nul
NUL
con
CON
prn
PRN
aux
AUX
com1
com2
lpt1
lpt2

# Accidental shell/pip artifacts
=*
_ul
how --stat *

# ── Example seed data: ship a working demo when the repo is cloned ──
# Re-includes the trained example model and the datasets, overriding the
# data/* and *.bin/*.pkl/*.npz/*.faiss ignores above. The RAG index stays
# ignored: each user uploads their own documentation in-app.
# User uploads (data/uploads/) and future sessions stay ignored too.
!data/session/
!data/session/**
!data/train_set.csv
!data/test_set.csv
