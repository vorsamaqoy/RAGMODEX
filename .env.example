# LLM providers
# At least one hosted provider key is required unless you use the local provider.
# Groq is a good default for quick local testing: https://console.groq.com

GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM defaults
DEFAULT_LLM_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# RAG configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
